---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={`${title} | NOVALUX`}>
  <Header />
  <main class="legal-page">
    <div class="container">
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>
