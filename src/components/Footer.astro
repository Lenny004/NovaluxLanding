---
const legalLinks = [
  { href: '/privacidad', label: 'Privacidad' },
  { href: '/aviso-legal', label: 'Aviso Legal' },
  { href: '/#contacto', label: 'Contacto' },
];
---

<footer class="site-footer">
  <div class="container site-footer-inner" data-reveal="fade">
    <a href="#" class="brand">
      <img src="/logo.png" alt="NOVALUX Energy Partners" />
    </a>

    <nav class="site-footer-nav" aria-label="Legal">
      {legalLinks.map((link) => (
        <a href={link.href} class="site-footer-link">{link.label}</a>
      ))}
    </nav>

    <p class="label-xs site-footer-copy">
      © 2026 NOVALUX Energy Partners. Todos los derechos reservados.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
    background: var(--color-navy);
    color: rgba(255, 255, 255, 0.8);
  }

  .site-footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding-block: 3rem;
    text-align: center;
  }

  .site-footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .site-footer-link {
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .site-footer-link:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  .site-footer-copy {
    color: rgba(255, 255, 255, 0.5);
  }

  @media (min-width: 48rem) {
    .site-footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }

    .site-footer-nav {
      margin-bottom: 0;
    }
  }
</style>
