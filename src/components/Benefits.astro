---
const benefits = [
  {
    icon: 'verified',
    iconBg: 'benefits-icon--navy',
    title: 'Las mejores compañías',
    text: 'Trabaja con un portfolio homologado de más de 40 empresas líderes en el sector energético y telecomunicaciones.',
  },
  {
    icon: 'account_balance_wallet',
    iconBg: 'benefits-icon--blue',
    title: 'Las mejores comisiones',
    text: 'Estructura de pagos transparente y altamente competitiva, diseñada para maximizar tu rentabilidad en cada cierre.',
  },
  {
    icon: 'speed',
    iconBg: 'benefits-icon--orange',
    title: 'Tramitación rápida',
    text: 'Plataforma ágil que reduce la burocracia. Alta en 24-48 horas y gestión de contratos sin fricciones.',
  },
];
---

<section class="benefits section" id="beneficios">
  <div class="container">
    <div class="benefits-header">
      <h2 class="headline-lg">Tu negocio, con la fuerza de NOVALUX detrás</h2>
      <p class="benefits-lead">
        Potencia tus ventas con un respaldo institucional sólido y herramientas diseñadas para escalar tus ingresos.
      </p>
    </div>

    <div class="benefits-grid">
      {benefits.map((item) => (
        <article class="benefits-card">
          <div class={`benefits-icon ${item.iconBg}`}>
            <span class="material-symbols-outlined">{item.icon}</span>
          </div>
          <h3 class="headline-md benefits-card-title">{item.title}</h3>
          <p class="body-md benefits-card-text">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits-header {
    max-width: 42rem;
    margin-inline: auto;
    margin-bottom: 4rem;
    text-align: center;
  }

  .benefits-header h2 {
    margin-bottom: 1rem;
    color: var(--color-navy);
  }

  .benefits-lead {
    color: var(--color-muted);
    font-size: var(--size-lg);
    line-height: 1.6;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .benefits-card {
    padding: 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid rgba(229, 234, 240, 0.5);
    box-shadow: var(--shadow-soft);
    transition: box-shadow 0.3s ease;
  }

  .benefits-card:hover {
    box-shadow: var(--shadow-lift);
  }

  .benefits-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1.5rem;
    border-radius: var(--radius-lg);
  }

  .benefits-icon .material-symbols-outlined {
    font-family: 'Material Symbols Outlined';
    font-size: 1.875rem;
  }

  .benefits-icon--navy {
    background: var(--color-cream);
    color: var(--color-navy);
  }

  .benefits-icon--blue {
    background: rgba(30, 95, 140, 0.12);
    color: var(--color-blue);
  }

  .benefits-icon--orange {
    background: rgba(247, 148, 29, 0.15);
    color: var(--color-orange);
  }

  .benefits-card-title {
    margin-bottom: 0.75rem;
    color: var(--color-navy);
  }

  .benefits-card-text {
    color: var(--color-muted);
  }

  @media (min-width: 48rem) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
