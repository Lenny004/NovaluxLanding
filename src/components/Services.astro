---
const services = [
  {
    title: 'Energía',
    description: 'Soluciones eléctricas para pymes y residenciales.',
    badge: 'Ahorro 20%',
    badgeColor: 'services__badge--navy',
    overlay: 'services__overlay--navy',
    icon: 'electric_bolt',
    image: '/light.png',
  },
  {
    title: 'Gas',
    description: 'Suministro de gas natural con tarifas optimizadas.',
    badge: 'Tarifa Plana',
    badgeColor: 'services__badge--blue',
    overlay: 'services__overlay--blue',
    icon: 'mode_heat',
    image: '/gas.png',
  },
  {
    title: 'Fibra',
    description: 'Conectividad de alta velocidad garantizada.',
    badge: '1Gbps',
    badgeColor: 'services__badge--orange',
    overlay: 'services__overlay--orange',
    icon: 'router',
    image: '/fiber.png',
  },
  {
    title: 'Móvil',
    description: 'Líneas corporativas y particulares flexibles.',
    badge: '5G Ilimitado',
    badgeColor: 'services__badge--navy',
    overlay: 'services__overlay--navy',
    icon: 'smartphone',
    image: '/mobile.png',
  },
];
---

<section class="services section" id="servicios">
  <div class="container">
    <header class="section-header" data-reveal>
      <h2 class="display-xl">Una oferta integral para tus clientes</h2>
      <p class="body-lg text-muted">
        No dejes escapar ninguna oportunidad. Cubre todas las necesidades de tus clientes con un solo proveedor.
      </p>
    </header>

    <div class="services__grid">
      {services.map((service, i) => (
        <article class="services__card card-lift" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
          <img class="services__image" src={service.image} alt={service.title} loading="lazy" />
          <div class={`services__overlay ${service.overlay}`}></div>
          <span class={`label-xs services__badge ${service.badgeColor}`}>{service.badge}</span>
          <div class="services__content">
            <div class="services__icon">
              <span class="material-symbols-outlined">{service.icon}</span>
            </div>
            <h3 class="headline-lg services__title">{service.title}</h3>
            <p class="label-xs services__desc">{service.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: #ffffff;
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .services__card {
    position: relative;
    height: 24rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .services__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .services__overlay {
    position: absolute;
    inset: 0;
  }

  .services__overlay--navy {
    background: linear-gradient(to top, rgba(14, 42, 77, 0.9), rgba(14, 42, 77, 0.2), transparent);
  }

  .services__overlay--blue {
    background: linear-gradient(to top, rgba(30, 95, 140, 0.9), rgba(30, 95, 140, 0.2), transparent);
  }

  .services__overlay--orange {
    background: linear-gradient(to top, rgba(247, 148, 29, 0.9), rgba(247, 148, 29, 0.2), transparent);
  }

  .services__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-weight: 700;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(0.625rem);
    box-shadow: var(--shadow-soft);
  }

  .services__badge--navy {
    color: var(--color-navy);
  }

  .services__badge--blue {
    color: var(--color-blue);
  }

  .services__badge--orange {
    color: var(--color-orange);
  }

  .services__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 1.5rem;
  }

  .services__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: 0.75rem;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(0.625rem);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .services__icon .material-symbols-outlined {
    font-family: 'Material Symbols Outlined';
    font-size: var(--size-s);
    color: #ffffff;
  }

  .services__title {
    margin-bottom: 0.25rem;
    color: #ffffff;
  }

  .services__desc {
    color: var(--color-bg);
  }

  @media (min-width: 40rem) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .services__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
