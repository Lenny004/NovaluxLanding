<section class="services section" id="servicios">
  <div class="container">
    <div class="services-header">
      <h2 class="headline-lg">Una oferta integral para tus clientes</h2>
      <p class="services-lead">
        No dejes escapar ninguna oportunidad. Cubre todas las necesidades de tus clientes con un solo proveedor.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <article class="services-card">
          <img class="services-image" src={service.image} alt={service.title} loading="lazy" />
          <div class={`services-overlay ${service.overlay}`}></div>
          <span class={`services-badge ${service.badgeColor}`}>{service.badge}</span>
          <div class="services-content">
            <div class="services-icon">
              <span class="material-symbols-outlined">{service.icon}</span>
            </div>
            <h3 class="headline-md services-title">{service.title}</h3>
            <p class="label-sm services-desc">{service.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: #ffffff;
  }

  .services-header {
    max-width: 36rem;
    margin-bottom: 4rem;
  }

  .services-header h2 {
    margin-bottom: 1rem;
    color: var(--color-navy);
  }

  .services-lead {
    color: var(--color-muted);
    font-size: var(--size-lg);
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .services-card {
    position: relative;
    height: 24rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: box-shadow 0.3s ease;
  }

  .services-card:hover {
    box-shadow: var(--shadow-lift);
  }

  .services-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .services-overlay {
    position: absolute;
    inset: 0;
  }

  .services-overlay--navy {
    background: linear-gradient(to top, rgba(14, 42, 77, 0.9), rgba(14, 42, 77, 0.2), transparent);
  }

  .services-overlay--blue {
    background: linear-gradient(to top, rgba(30, 95, 140, 0.9), rgba(30, 95, 140, 0.2), transparent);
  }

  .services-overlay--orange {
    background: linear-gradient(to top, rgba(247, 148, 29, 0.9), rgba(247, 148, 29, 0.2), transparent);
  }

  .services-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--size-xs);
    font-weight: 700;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(0.625rem);
    box-shadow: var(--shadow-soft);
  }

  .services-badge--navy {
    color: var(--color-navy);
  }

  .services-badge--blue {
    color: var(--color-blue);
  }

  .services-badge--orange {
    color: var(--color-orange);
  }

  .services-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 1.5rem;
  }

  .services-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: 0.75rem;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(0.625rem);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .services-icon .material-symbols-outlined {
    font-family: 'Material Symbols Outlined';
    font-size: var(--size-s);
    color: #ffffff;
  }

  .services-title {
    margin-bottom: 0.25rem;
    color: #ffffff;
  }

  .services-desc {
    color: rgba(255, 255, 255, 0.8);
  }

  @media (min-width: 40rem) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .services-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
