---
const navLinks = [
  { href: '#beneficios', label: 'Beneficios' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#comisiones', label: 'Comisiones' },
  { href: '#comisiones', label: 'Cómo funciona' },
];
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a href="#" class="brand">
      <img src="/logo.png" alt="" width="36" height="36" class="brand-logo" />
      <span class="brand-text">NOVALUX Energy Partners</span>
    </a>

    <nav class="nav-desktop" aria-label="Principal">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <a href="#contacto" class="cta-desktop">Quiero ser colaborador</a>

    <button
      type="button"
      class="menu-toggle"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
    >
      <span class="material-symbols-outlined menu-icon" data-menu-icon>menu</span>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="mobile-menu"
    data-mobile-menu
    aria-label="Menú móvil"
    hidden
  >
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
    <a href="#contacto" class="mobile-cta">Quiero ser colaborador</a>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const toggle = header?.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = header?.querySelector<HTMLElement>('[data-mobile-menu]');
  const icon = header?.querySelector<HTMLElement>('[data-menu-icon]');

  if (toggle && menu && icon) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle('open', open);
      menu.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      icon.textContent = open ? 'close' : 'menu';
    };

    toggle.addEventListener('click', () => {
      setOpen(!menu.classList.contains('open'));
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    window.addEventListener('resize', () => {
      if (window.matchMedia('(min-width: 48rem)').matches) {
        setOpen(false);
      }
    });
  }
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(246, 248, 251, 0.85);
    backdrop-filter: blur(0.75rem);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    min-width: 0;
  }

  .brand-logo {
    flex-shrink: 0;
    border-radius: var(--radius-lg);
  }

  .brand-text {
    font-size: calc(var(--font-size-lg) * 0.9);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-navy);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: var(--font-size-s);
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-blue);
  }

  .cta-desktop {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.5rem;
    border-radius: var(--radius-xl);
    font-size: var(--font-size-s);
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-navy);
    background: var(--color-cream);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .cta-desktop:hover {
    background: var(--color-navy);
    color: #ffffff;
    transform: scale(1);
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border: none;
    background: transparent;
    color: var(--color-navy);
    cursor: pointer;
  }

  .menu-icon {
    font-family: 'Material Symbols Outlined';
    font-size: 1.75rem;
    line-height: 1;
    font-variation-settings: 'FILL' 0;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem var(--gutter) 1.25rem;
    border-top: 1px solid var(--color-border);
    background: rgba(246, 248, 251, 0.95);
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-link {
    padding: 0.75rem 0;
    font-size: var(--font-size-s);
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .mobile-link:hover {
    color: var(--color-blue);
  }

  .mobile-cta {
    margin-top: 0.5rem;
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius-xl);
    font-size: var(--font-size-s);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-align: center;
    color: #ffffff;
    background: var(--color-navy);
    transition: background-color 0.2s ease;
  }

  .mobile-cta:hover {
    background: var(--color-blue);
  }

  @media (min-width: 48rem) {
    .nav-desktop {
      display: flex;
    }

    .cta-desktop {
      display: inline-flex;
    }

    .menu-toggle {
      display: none;
    }

    .mobile-menu {
      display: none !important;
    }
  }

  @media (max-width: 30rem) {
    .brand-text {
      font-size: var(--font-size-s);
    }
  }
</style>
