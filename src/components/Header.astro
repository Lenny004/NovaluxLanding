---
const navLinks = [
  { href: '#beneficios', label: 'Beneficios' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#comisiones', label: 'Comisiones' },
  { href: '#testimonios', label: 'Opiniones' },
];
---

<header class="site-header" data-header>
  <div class="container site-header__inner">
    <a href="#" class="brand">
      <img src="/logo.png" alt="logo"/>
    </a>

    <nav class="site-header__nav" aria-label="Principal">
      {navLinks.map((link) => (
        <a href={link.href} class="site-header__link">{link.label}</a>
      ))}
    </nav>

    <a href="#contacto" class="site-header__cta">Quiero ser colaborador</a>

    <button
      type="button"
      class="site-header__toggle"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
    >
      <span class="material-symbols-outlined site-header__toggle-icon" data-menu-icon>menu</span>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="site-header__menu"
    data-mobile-menu
    aria-label="Menú móvil"
    hidden
  >
    {navLinks.map((link) => (
      <a href={link.href} class="site-header__menu-link">{link.label}</a>
    ))}
    <a href="#contacto" class="site-header__menu-cta">Quiero ser colaborador</a>
  </nav>
</header>

<script>
  import { initSiteHeader } from '../scripts/site-header';

  initSiteHeader();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--color-bg);
    backdrop-filter: blur(0.75rem);
    border-bottom-left-radius: var(--radius-2xl);
    border-bottom-right-radius: var(--radius-2xl);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1rem;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  .site-header__link {
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .site-header__link:hover {
    color: var(--color-navy);
  }

  .site-header__cta {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-xl);
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-bg);
    background: var(--color-navy);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .site-header__cta:hover {
    background: var(--color-blue);
    color: #ffffff;
    transform: translateY(-0.125rem);
    box-shadow: var(--shadow-soft);
  }

  .site-header__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border: none;
    background: transparent;
    color: var(--color-navy);
    cursor: pointer;
  }

  .site-header__toggle-icon {
    font-family: 'Material Symbols Outlined';
    font-size: var(--size-icon-nav);
  }

  .site-header__menu {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem var(--gutter) 1.25rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .site-header__menu--open {
    display: flex;
  }

  .site-header__menu-link {
    padding: 0.75rem 0;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .site-header__menu-link:hover {
    color: var(--color-navy);
  }

  .site-header__menu-cta {
    margin-top: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-xl);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-align: center;
    color: var(--color-bg);
    background: var(--color-navy);
    transition: background-color 0.2s ease;
  }

  .site-header__menu-cta:hover {
    background: var(--color-blue);
  }

  @media (min-width: 48rem) {
    .site-header__nav {
      display: flex;
    }

    .site-header__cta {
      display: inline-flex;
    }

    .site-header__toggle {
      display: none;
    }

    .site-header__menu {
      display: none !important;
    }
  }

  @media (max-width: 30rem) {
    .brand-text {
      font-size: var(--size-s);
    }
  }
</style>
