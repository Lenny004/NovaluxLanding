---
const benefits = [
  'Porcentaje de ahorro estimado',
  'Ahorro en euros al mes y al año',
  'Mejor tarifa disponible para ti',
];

const householdOptions = ['1 persona', '2 personas', '3 personas', '4 personas', '5 o más'];

const providers = [
  'Iberdrola',
  'Endesa',
  'Naturgy',
  'Repsol',
  'Plenitude (Aldro)',
  'Holaluz',
  'Gana Energía',
  'Otra',
];

const economicOptions = [
  'Llego justo a fin de mes',
  'Cubro gastos y ahorro algo',
  'Vivo con holgura',
  'El dinero no es una preocupación',
];

const livingOptions = [
  'Solo/a',
  'Con mi pareja',
  'Con mi pareja e hijos',
  'Con mis hijos',
  'Con otros familiares',
  'Con compañeros de piso',
];

const crmEndpoint = import.meta.env.PUBLIC_CRM_LANDING_LEADS_ENDPOINT ?? 'https://TU_DOMINIO_CRM/PTR-Sales/api/public/api_landing_leads.php?action=create';
const crmApiKey = import.meta.env.PUBLIC_NOVALUX_LANDING_API_KEY ?? '';
---

<section class="calculator section" id="calculadora">
  <div class="container">
    <header class="section-header" data-reveal>
      <h2 class="display-xl">Calculadora</h2>
      <p class="body-lg text-muted">Luz y gas, cuánto puedes ahorrar con la mejor tarifa.</p>
    </header>

    <div
      class="calculator-panel card-lift"
      data-calc-root
      data-endpoint={crmEndpoint}
      data-api-key={crmApiKey}
      data-source="novalux"
      data-reveal
    >
      <!-- Intro -->
      <div class="calc-view" data-calc-view="intro">
        <span class="calc-badge label-xs">Calculadora gratuita</span>
        <h3 class="calc-title display-xl">¿Cuánto podrías ahorrar en tu factura de luz?</h3>
        <p class="calc-lead body-lg text-muted">
          Responde unas preguntas y descubre si estás pagando de más — y qué tarifa te conviene.
        </p>
        <p class="calc-highlight label-s">
          Ahorro medio: <strong>35€/mes</strong>
        </p>

        <ul class="calc-benefits">
          {benefits.map((item) => (
            <li class="calc-benefit">
              <span class="material-symbols-outlined calc-benefit-icon" aria-hidden="true">check_circle</span>
              {item}
            </li>
          ))}
        </ul>

        <button type="button" class="calc-cta btn-primary" data-calc-start>
          <span class="calc-cta-main">Empezar el análisis</span>
          <span class="calc-cta-sub">Gratis · Sin compromiso · 2 minutos</span>
        </button>
      </div>

      <!-- Wizard -->
      <div class="calc-view calc-view--wizard" data-calc-view="wizard" hidden>
        <div class="calc-progress" aria-hidden="true">
          <div class="calc-progress-fill" data-calc-progress></div>
        </div>

        <div class="calc-step" data-calc-step="0">
          <h3 class="calc-step-title display-xl">¿Qué quieres analizar?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            <label class="calc-option"><input type="radio" name="serviceType" value="luz" /><span class="calc-option-ui"></span>Solo luz</label>
            <label class="calc-option"><input type="radio" name="serviceType" value="luz-gas" /><span class="calc-option-ui"></span>Luz y gas</label>
          </div>
        </div>

        <div class="calc-step" data-calc-step="1" hidden>
          <h3 class="calc-step-title display-xl">¿Cuánto pagas de luz al mes?</h3>
          <p class="calc-step-sub body-lg text-muted">Mira tu última factura</p>
          <input class="calc-input" type="number" name="monthlyBill" min="1" placeholder="Ej: 80" inputmode="decimal" />
          <button type="button" class="calc-continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calc-step" data-calc-step="2" hidden>
          <h3 class="calc-step-title display-xl">¿Cuántas personas viven en casa?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {householdOptions.map((label, i) => (
              <label class="calc-option">
                <input type="radio" name="householdSize" value={String(i + 1)} />
                <span class="calc-option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calc-step" data-calc-step="3" hidden>
          <h3 class="calc-step-title display-xl">¿Sabes tu potencia contratada?</h3>
          <p class="calc-step-sub body-lg text-muted">La encontrarás en tu factura de luz</p>
          <div class="calc-options" role="radiogroup">
            <label class="calc-option"><input type="radio" name="knowsPower" value="yes" /><span class="calc-option-ui"></span>Sí, la sé</label>
            <label class="calc-option"><input type="radio" name="knowsPower" value="no" /><span class="calc-option-ui"></span>No lo sé</label>
          </div>
        </div>

        <div class="calc-step" data-calc-step="4" hidden>
          <h3 class="calc-step-title display-xl">¿Sabes el precio de tu kWh?</h3>
          <p class="calc-step-sub body-lg text-muted">Lo encontrarás en el detalle de tu factura</p>
          <div class="calc-options" role="radiogroup">
            <label class="calc-option"><input type="radio" name="knowsKwh" value="yes" /><span class="calc-option-ui"></span>Sí, lo sé</label>
            <label class="calc-option"><input type="radio" name="knowsKwh" value="no" /><span class="calc-option-ui"></span>No lo sé</label>
          </div>
        </div>

        <div class="calc-step" data-calc-step="5" hidden>
          <h3 class="calc-step-title display-xl">¿Qué tipo de tarifa tienes?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            <label class="calc-option"><input type="radio" name="tariffType" value="pvpc" /><span class="calc-option-ui"></span>PVPC (tarifa regulada)</label>
            <label class="calc-option"><input type="radio" name="tariffType" value="libre" /><span class="calc-option-ui"></span>Mercado libre</label>
            <label class="calc-option"><input type="radio" name="tariffType" value="unknown" /><span class="calc-option-ui"></span>No lo sé</label>
          </div>
        </div>

        <div class="calc-step" data-calc-step="6" hidden>
          <h3 class="calc-step-title display-xl">¿Cuál es tu proveedor actual?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción *</p>
          <div class="calc-options" role="radiogroup">
            {providers.map((label) => (
              <label class="calc-option">
                <input type="radio" name="provider" value={label} />
                <span class="calc-option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calc-step" data-calc-step="7" hidden>
          <h3 class="calc-step-title display-xl">¿Cómo describirías tu situación económica actual?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción *</p>
          <div class="calc-options" role="radiogroup">
            {economicOptions.map((label) => (
              <label class="calc-option">
                <input type="radio" name="economicSituation" value={label} />
                <span class="calc-option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calc-step" data-calc-step="8" hidden>
          <h3 class="calc-step-title display-xl">¿Con quién vives?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción *</p>
          <div class="calc-options" role="radiogroup">
            {livingOptions.map((label) => (
              <label class="calc-option">
                <input type="radio" name="livingWith" value={label} />
                <span class="calc-option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calc-step" data-calc-step="9" hidden>
          <h3 class="calc-step-title display-xl">¿Cuál es tu código postal?</h3>
          <p class="calc-step-sub body-lg text-muted">Introduce tu código postal *</p>
          <input class="calc-input" type="text" name="postalCode" placeholder="Ej: 28001" maxlength="5" inputmode="numeric" pattern="[0-9]{5}" />
          <button type="button" class="calc-continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calc-step" data-calc-step="10" hidden>
          <h3 class="calc-step-title display-xl">¿Cómo te llamas?</h3>
          <p class="calc-step-sub body-lg text-muted">Introduce tu nombre completo *</p>
          <p class="calc-privacy-note body-md">
            Para enviarte el resultado personalizado, necesitamos tu contacto. Solo guardaremos tus datos en nuestro CRM si aceptas la política de privacidad.
          </p>
          <input class="calc-input" type="text" name="firstName" placeholder="Nombre" autocomplete="given-name" />
          <input class="calc-input" type="text" name="lastName" placeholder="Introduce tu apellido" autocomplete="family-name" />
          <button type="button" class="calc-continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calc-step" data-calc-step="11" hidden>
          <h3 class="calc-step-title display-xl">¿Cuál es tu número de teléfono?</h3>
          <p class="calc-step-sub body-lg text-muted">Introduce tu teléfono *</p>
          <input class="calc-input" type="tel" name="phone" placeholder="600 00 00 00" autocomplete="tel" />
          <label class="calc-consent">
            <input type="checkbox" name="privacy" />
            <span class="body-md text-muted">
              Acepto que NOVALUX Energy Partners trate mis datos personales y los registre para contactarme con la mejor oferta energética. Puedo retirar mi consentimiento en cualquier momento. <a href="/privacidad">Política de privacidad</a>.
            </span>
          </label>
          <button type="button" class="calc-continue btn-primary" data-calc-finish>Continuar</button>
        </div>

        <div class="calc-nav">
          <button type="button" class="calc-back btn-secondary" data-calc-back hidden>
            <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
            Atrás
          </button>
        </div>
      </div>

      <!-- Results -->
      <div class="calc-view calc-view--results" data-calc-view="results" hidden>
        <div class="calc-result-card">
          <p class="calc-result-label label-xs">Resultado del análisis</p>
          <p class="calc-result-percent display-xl" data-calc-result-percent>12%</p>
          <p class="calc-result-desc body-lg">de ahorro estimado en tu factura</p>
          <p class="calc-result-badge label-s" data-calc-result-savings>9,84€/mes · 118,08€/año</p>

          <div class="calc-result-cta-wrap">
            <p class="body-md text-muted">Encuentra la tarifa que mejor encaja contigo hoy</p>
            <a href="#contacto" class="calc-cta btn-primary" data-calc-result-cta>
              <span class="calc-cta-main">Quiero pagar menos →</span>
              <span class="calc-cta-sub">Gratis · Sin compromiso · 5 minutos</span>
            </a>
          </div>
        </div>

        <p class="calc-comparison-label label-xs text-muted">Factura de luz</p>
        <div class="calc-comparison card-lift">
          <div class="calc-comparison-row">
            <div>
              <p class="label-xs text-muted">Pagas ahora</p>
              <p class="calc-comparison-bad label-xs">✕ Tarifa sin optimizar</p>
            </div>
            <p class="calc-comparison-amount" data-calc-result-current>80,00€</p>
          </div>
          <div class="calc-comparison-bar">
            <span class="material-symbols-outlined" aria-hidden="true">south</span>
            Cambiando de tarifa
          </div>
          <div class="calc-comparison-row calc-comparison-row--new">
            <div>
              <p class="label-s calc-comparison-good">Tu nueva factura</p>
              <ul class="calc-comparison-perks">
                <li>✓ Potencia optimizada</li>
                <li>✓ Mejor tarifa del mercado</li>
                <li>✓ Sin permanencia</li>
              </ul>
            </div>
            <p class="calc-comparison-amount calc-comparison-amount--new" data-calc-result-new>70,16€</p>
          </div>
        </div>

        <p class="calc-comparison-label label-xs text-muted">Por qué estás pagando de más</p>
        <div class="calc-why card-lift">
          <p class="body-md"><span class="calc-why-x" aria-hidden="true">✕</span> <strong>Tu comercializadora nunca te llamará</strong> para ofrecerte una tarifa más barata — no es su interés.</p>
          <p class="body-md"><span class="calc-why-x" aria-hidden="true">✕</span> <strong>Las mejores tarifas no se publicitan.</strong> Hay que saber dónde buscarlas y negociarlas.</p>
        </div>

        <button type="button" class="calc-restart btn-secondary" data-calc-restart>Volver a calcular</button>
      </div>
    </div>
  </div>
</section>

<script>
  import {
    buildLeadBody,
    calculatorToLeadFields,
    createCalculatorSession,
    getSessionToken,
    saveCalculatorData,
    setSessionTokenOverride,
    submitLandingLead,
  } from '../lib/landingLead';

  const root = document.querySelector<HTMLElement>('[data-calc-root]');
  if (!root) throw new Error('Calculator root not found');

  const views = {
    intro: root.querySelector<HTMLElement>('[data-calc-view="intro"]')!,
    wizard: root.querySelector<HTMLElement>('[data-calc-view="wizard"]')!,
    results: root.querySelector<HTMLElement>('[data-calc-view="results"]')!,
  };

  const steps = Array.from(root.querySelectorAll<HTMLElement>('[data-calc-step]'));
  const progressFill = root.querySelector<HTMLElement>('[data-calc-progress]')!;
  const backBtn = root.querySelector<HTMLButtonElement>('[data-calc-back]')!;
  const totalSteps = steps.length;

  let currentStep = 0;

  const formatEuro = (value: number) =>
    value.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '€';

  const showView = (name: keyof typeof views) => {
    Object.entries(views).forEach(([key, el]) => {
      el.hidden = key !== name;
    });
  };

  const showStep = (index: number) => {
    currentStep = index;
    steps.forEach((step, i) => {
      step.hidden = i !== index;
    });
    progressFill.style.width = `${((index + 1) / totalSteps) * 100}%`;
    backBtn.hidden = index === 0;
  };

  const getFormData = () => {
    const data: Record<string, string> = {};
    root.querySelectorAll<HTMLInputElement>('input[name]').forEach((input) => {
      if (input.type === 'radio' && !input.checked) return;
      if (input.type === 'checkbox') {
        data[input.name] = input.checked ? 'yes' : 'no';
        return;
      }
      data[input.name] = input.value.trim();
    });
    return data;
  };

  const calculateSavings = (data: Record<string, string>) => {
    const bill = Math.max(parseFloat(data.monthlyBill) || 80, 1);
    let percent = 10;

    if (data.serviceType === 'luz-gas') percent += 2;
    if (data.knowsPower === 'no') percent += 2;
    if (data.knowsKwh === 'no') percent += 2;
    if (data.tariffType === 'pvpc') percent += 3;
    if (data.tariffType === 'unknown') percent += 4;
    if (data.tariffType === 'libre') percent += 1;

    percent = Math.min(Math.round(percent), 25);
    const newBill = bill * (1 - percent / 100);
    const monthlySaving = bill - newBill;

    return { percent, bill, newBill, monthlySaving, yearlySaving: monthlySaving * 12 };
  };

  const validateStep = (index: number): boolean => {
    const step = steps[index];
    const inputs = step.querySelectorAll<HTMLInputElement>('input[name]');

    for (const input of inputs) {
      if (input.type === 'radio') {
        const group = step.querySelector<HTMLInputElement>(`input[name="${input.name}"]:checked`);
        if (!group) return false;
        continue;
      }
      if (input.type === 'checkbox') {
        if (input.name === 'privacy' && !input.checked) return false;
        continue;
      }
      if (!input.value.trim()) return false;
    }
    return true;
  };

  const goNext = () => {
    if (!validateStep(currentStep)) return;
    if (currentStep < totalSteps - 1) {
      showStep(currentStep + 1);
      return;
    }
    finishWizard();
  };

  const finishWizard = async () => {
    if (!validateStep(currentStep)) return;
    const data = getFormData();
    const result = calculateSavings(data);

    root.querySelector('[data-calc-result-percent]')!.textContent = `${result.percent}%`;
    root.querySelector('[data-calc-result-savings]')!.textContent =
      `${formatEuro(result.monthlySaving)}/mes · ${formatEuro(result.yearlySaving)}/año`;
    root.querySelector('[data-calc-result-current]')!.textContent = formatEuro(result.bill);
    root.querySelector('[data-calc-result-new]')!.textContent = formatEuro(result.newBill);

    const cta = root.querySelector<HTMLAnchorElement>('[data-calc-result-cta]');
    if (cta) {
      const ctaMain = cta.querySelector('.calc-cta-main');
      const ctaSub = cta.querySelector('.calc-cta-sub');
      if (ctaMain) ctaMain.textContent = `Quiero ahorrar ${formatEuro(result.monthlySaving)}/mes →`;
      if (ctaSub) ctaSub.textContent = 'Gratis · Sin compromiso · 5 minutos';
    }

    const payload = { answers: data, result };
    saveCalculatorData(payload);
    showView('results');

    const endpoint = root.dataset.endpoint;
    const apiKey = root.dataset.apiKey;
    const source = root.dataset.source || 'novalux';

    if (!endpoint || !apiKey) return;

    const calcSessEndpoint = endpoint.replace('api_landing_leads.php', 'api_calculator_session.php');
    const sessionData = await createCalculatorSession(calcSessEndpoint, apiKey, source, 'energy', data, result);
    const sessionToken = sessionData?.session_token || getSessionToken();
    if (sessionData?.session_token) {
      setSessionTokenOverride(sessionData.session_token);
    }

    try {
      const fields = calculatorToLeadFields(payload);
      const body = buildLeadBody({
        source,
        leadOrigin: 'calculator',
        fullName: fields.fullName,
        phone: fields.phone,
        postalCode: fields.postalCode,
        monthlyBill: fields.monthlyBill,
        savingsPercent: fields.savingsPercent,
        monthlySaving: fields.monthlySaving,
        approximateConsumption: fields.approximateConsumption,
        serviceLuz: fields.serviceLuz,
        serviceGas: fields.serviceGas,
        calculatorData: payload,
        sessionToken,
      });
      await submitLandingLead(endpoint, apiKey, body);
      saveCalculatorData({ ...payload, sessionToken, submittedToCrm: true, submittedAt: new Date().toISOString() });
    } catch {
      // El usuario ve el resultado aunque falle el envío; contacto puede reenviar los datos.
    }
  };

  root.querySelector('[data-calc-start]')?.addEventListener('click', () => {
    showView('wizard');
    showStep(0);
  });

  root.querySelector('[data-calc-restart]')?.addEventListener('click', () => {
    root.querySelectorAll('input').forEach((input) => {
      if (input.type === 'radio' || input.type === 'checkbox') input.checked = false;
      else input.value = '';
    });
    showView('intro');
  });

  backBtn.addEventListener('click', () => {
    if (currentStep > 0) showStep(currentStep - 1);
  });

  root.querySelectorAll('[data-calc-next]').forEach((btn) => {
    btn.addEventListener('click', goNext);
  });

  root.querySelector('[data-calc-finish]')?.addEventListener('click', finishWizard);

  root.querySelectorAll('.calc-option input[type="radio"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      window.setTimeout(() => {
        if (currentStep < totalSteps - 1 && validateStep(currentStep)) {
          showStep(currentStep + 1);
        }
      }, 280);
    });
  });

  root.querySelectorAll('.calc-input').forEach((input) => {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') goNext();
    });
  });
</script>

<style>
  .calculator {
    scroll-margin-top: 5rem;
    background: var(--color-bg);
  }

  .calculator-panel {
    max-width: 36rem;
    margin-inline: auto;
    padding: 2.5rem 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid rgba(229, 234, 240, 0.8);
    text-align: center;
  }

  .calc-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .calc-view[hidden],
  .calc-step[hidden] {
    display: none;
  }

  .calc-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(30, 95, 140, 0.45);
    color: var(--color-blue);
    background: rgba(30, 95, 140, 0.08);
  }

  .calc-title {
    font-size: calc(var(--size-xl) * 0.72);
  }

  .calc-lead {
    max-width: 28rem;
  }

  .calc-highlight {
    color: var(--color-blue);
  }

  .calc-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    list-style: none;
  }

  @media (min-width: 40rem) {
    .calc-benefits {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  .calc-benefit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
    font-size: var(--size-xs);
    font-weight: 600;
    text-align: left;
  }

  .calc-benefit-icon {
    font-size: 1.25rem;
    color: var(--color-orange);
  }

  .calc-cta {
    flex-direction: column;
    width: 100%;
    padding-block: 1.1rem;
    gap: 0.25rem;
  }

  .calc-cta-main {
    font-size: var(--size-s);
    font-weight: 700;
  }

  .calc-cta-sub {
    font-size: var(--size-xs);
    font-weight: 500;
    opacity: 0.9;
  }

  .calc-view--wizard {
    width: 100%;
    gap: 2rem;
  }

  .calc-progress {
    width: 100%;
    height: 0.25rem;
    border-radius: var(--radius-full);
    background: var(--color-border);
    overflow: hidden;
  }

  .calc-progress-fill {
    height: 100%;
    width: 0;
    border-radius: inherit;
    background: var(--color-blue);
    transition: width 0.35s ease;
  }

  .calc-step {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1.25rem;
    width: 100%;
  }

  .calc-step-title {
    font-size: calc(var(--size-xl) * 0.65);
    text-align: center;
  }

  .calc-step-sub {
    text-align: center;
    margin-top: -0.5rem;
  }

  .calc-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .calc-option {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.15rem;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(30, 95, 140, 0.35);
    background: #ffffff;
    cursor: pointer;
    font-weight: 600;
    text-align: left;
    transition: border-color 0.2s ease, background-color 0.2s ease;
