---
const phases = [
  {
    phase: 'Fase 1',
    title: 'Activación',
    text: 'Cobra un upfront competitivo por cada nuevo contrato dado de alta en la plataforma, abonado rápidamente.',
    accent: 'commissions__marker--orange',
    phaseColor: 'commissions__phase--orange',
  },
  {
    phase: 'Fase 2',
    title: 'Recurrencia',
    text: 'Construye una cartera que te genere ingresos mes a mes. Tu esfuerzo de hoy rinde frutos a largo plazo.',
    accent: 'commissions__marker--blue',
    phaseColor: 'commissions__phase--blue',
  },
  {
    phase: 'Fase 3',
    title: 'Sin límite de ingresos',
    text: 'No hay topes ni barreras. Cuanto más crezcas, mejores condiciones y bonus por volumen podrás alcanzar.',
    accent: 'commissions__marker--gold',
    phaseColor: 'commissions__phase--gold',
  },
];
---

<section class="commissions section" id="comisiones">
  <div class="commissions__glow" aria-hidden="true"></div>

  <div class="container commissions__inner">
    <div class="commissions__grid">
      <div class="commissions__intro" data-reveal>
        <h2 class="display-xl commissions__title">Comisiones pensadas para que crezcas</h2>
        <p class="body-lg text-inverse commissions__lead">
          Nuestro modelo de retribución está diseñado para premiar tanto la captación como la fidelización de tu cartera.
        </p>
        <a href="#contacto" class="btn-primary commissions__cta">
          Solicitar dossier de comisiones
        </a>
      </div>

      <div class="commissions__timeline">
        <div class="commissions__line" aria-hidden="true"></div>
        {phases.map((item, i) => (
          <div class="commissions__item" data-reveal style={`--reveal-delay: ${i * 120}ms`}>
            <div class={`commissions__marker ${item.accent}`} aria-hidden="true">
              <span class="commissions__dot"></span>
            </div>
            <div class="commissions__item-content">
              <span class={`label-s commissions__phase ${item.phaseColor}`}>{item.phase}</span>
              <h3 class="headline-lg commissions__item-title">{item.title}</h3>
              <p class="body-md text-inverse-soft commissions__item-text">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .commissions {
    position: relative;
    overflow: hidden;
    background: var(--color-navy);
    color: #ffffff;
    border-radius: var(--radius-2xl);
  }

  .commissions__glow {
    position: absolute;
    top: 50%;
    right: 0;
    translate: 0 -50%;
    width: 37.5rem;
    height: 37.5rem;
    border-radius: var(--radius-full);
    background: rgba(30, 95, 140, 0.3);
    filter: blur(6.25rem);
    pointer-events: none;
  }

  .commissions__inner {
    position: relative;
    z-index: 1;
  }

  .commissions__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .commissions__title {
    margin-bottom: 1.5rem;
    color: #ffffff;
  }

  .commissions__lead {
    margin-bottom: 2rem;
  }

  .commissions__cta {
    width: 100%;
  }

  .commissions__timeline {
    position: relative;
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .commissions__line {
    position: absolute;
    left: 0.6875rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: rgba(255, 255, 255, 0.1);
  }

  .commissions__item {
    position: relative;
  }

  .commissions__marker {
    position: absolute;
    left: -2rem;
    top: 0.375rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-full);
    background: var(--color-navy);
    border: 2px solid;
  }

  .commissions__marker--orange {
    border-color: var(--color-orange);
    box-shadow: 0 0 0.9375rem rgba(247, 148, 29, 0.4);
  }

  .commissions__marker--blue {
    border-color: var(--color-blue);
    box-shadow: 0 0 0.9375rem rgba(30, 95, 140, 0.4);
  }

  .commissions__marker--gold {
    border-color: var(--color-gold);
    box-shadow: 0 0 0.9375rem rgba(255, 193, 7, 0.4);
  }

  .commissions__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
  }

  .commissions__marker--orange .commissions__dot {
    background: var(--color-orange);
  }

  .commissions__marker--blue .commissions__dot {
    background: var(--color-blue);
  }

  .commissions__marker--gold .commissions__dot {
    background: var(--color-gold);
  }

  .commissions__item-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .commissions__phase {
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .commissions__phase--orange {
    color: var(--color-orange);
  }

  .commissions__phase--blue {
    color: var(--color-blue);
  }

  .commissions__phase--gold {
    color: var(--color-gold);
  }

  .commissions__item-title {
    color: #ffffff;
  }

  .commissions__item-text {
    max-width: 32rem;
  }

  @media (min-width: 40rem) {
    .commissions__cta {
      width: auto;
    }
  }

  @media (min-width: 64rem) {
    .commissions__grid {
      grid-template-columns: 5fr 6fr;
      gap: 3rem;
    }

    .commissions__timeline {
      grid-column: 2;
    }
  }
</style>
