---
const perks = [
  'Sin cuotas de entrada',
  'Formación continua gratuita',
  'Soporte dedicado',
];

const clientTypes = [
  { label: 'Autónomo', value: 'autonomo' },
  { label: 'Empresa', value: 'empresa' },
  { label: 'Particular', value: 'particular' },
];

const crmEndpoint = import.meta.env.PUBLIC_CRM_LANDING_LEADS_ENDPOINT ?? 'https://TU_DOMINIO_CRM/PTR-Sales/api/public/api_landing_leads.php?action=create';
const crmApiKey = import.meta.env.PUBLIC_NOVALUX_LANDING_API_KEY ?? '';
---

<section class="contact section" id="contacto">
  <div class="container">
    <div class="contact-panel" data-reveal>
      <div class="contact-glow" aria-hidden="true"></div>

      <div class="contact-grid">
        <div class="contact-intro">
          <h2 class="display-xl contact-title">Únete a la red líder hoy</h2>
          <p class="body-lg text-inverse contact-lead">
            Déjanos tus datos y un asesor se pondrá en contacto contigo para explicarte el programa de colaboración y darte de alta.
          </p>

          <ul class="contact-perks">
            {perks.map((perk) => (
              <li class="contact-perk">
                <span class="material-symbols-outlined contact-perk-icon" aria-hidden="true">check_circle</span>
                <span class="body-md">{perk}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="contact-form-wrap">
          <form
            class="contact-form"
            method="post"
            enctype="multipart/form-data"
            data-contact-form
            data-endpoint={crmEndpoint}
            data-api-key={crmApiKey}
            data-source="novalux"
          >
            <div class="contact-field">
              <label class="label-s contact-label" for="contact-name">Nombre completo</label>
              <input
                class="contact-input"
                id="contact-name"
                name="name"
                type="text"
                placeholder="Ej. Juan Pérez"
                required
              />
            </div>

            <div class="contact-row">
              <div class="contact-field">
                <label class="label-s contact-label" for="contact-phone">Teléfono</label>
                <input
                  class="contact-input"
                  id="contact-phone"
                  name="phone"
                  type="tel"
                  placeholder="+34 600 000 000"
                  required
                />
              </div>
              <div class="contact-field">
                <label class="label-s contact-label" for="contact-email">Email</label>
                <input
                  class="contact-input"
                  id="contact-email"
                  name="email"
                  type="email"
                  placeholder="juan@email.com"
                  required
                />
              </div>
            </div>

            <div class="contact-field">
              <label class="label-s contact-label" for="contact-client-type">Tipo de cliente</label>
              <select class="contact-input" id="contact-client-type" name="client_type" required>
                <option value="" disabled selected>Selecciona una opción</option>
                {clientTypes.map((type) => (
                  <option value={type.value}>{type.label}</option>
                ))}
              </select>
            </div>

            <div class="contact-field">
              <label class="label-s contact-label" for="contact-consumption">Consumo aproximado</label>
              <input
                class="contact-input"
                id="contact-consumption"
                name="approximate_consumption"
                type="text"
                placeholder="Ej. 150€/mes o 3.500 kWh/año"
              />
            </div>

            <fieldset class="contact-field contact-fieldset">
              <legend class="label-s contact-label">Servicios de interés</legend>
              <div class="contact-checks">
                <label class="contact-check">
                  <input type="checkbox" name="service_luz" value="1" />
                  <span>Luz</span>
                </label>
                <label class="contact-check">
                  <input type="checkbox" name="service_gas" value="1" />
                  <span>Gas</span>
                </label>
              </div>
            </fieldset>

            <div class="contact-field">
              <span class="label-s contact-label" id="contact-invoice-label">Subir factura</span>
              <div class="contact-file-wrap" data-file-wrap>
                <input
                  class="contact-file-input"
                  id="contact-invoice"
                  name="invoice"
                  type="file"
                  accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/jpeg,image/png"
                  aria-labelledby="contact-invoice-label contact-invoice-name"
                  data-contact-file
                />
                <label class="contact-file-dropzone" for="contact-invoice" data-file-dropzone>
                  <span class="material-symbols-outlined contact-file-icon" aria-hidden="true">upload_file</span>
                  <span class="contact-file-copy">
                    <span class="label-s contact-file-cta">Seleccionar archivo</span>
                    <span class="label-xs text-muted contact-file-name" id="contact-invoice-name" data-file-name>
                      o arrastra aquí
                    </span>
                  </span>
                </label>
              </div>
              <p class="label-xs text-muted contact-file-hint">PDF, JPG o PNG. Máximo 10 MB.</p>
            </div>

            <button class="btn-primary contact-submit" type="submit">
              Solicitar información
            </button>

            <p class="label-s contact-status" data-form-status aria-live="polite"></p>

            <p class="label-xs text-muted contact-disclaimer">
              Al enviar aceptas nuestra <a class="label-xs" href="/privacidad">política de privacidad</a>.
            </p>
          </form>

          <div class="contact-success" data-contact-success hidden>
            <div class="contact-success-icon" aria-hidden="true">
              <span class="material-symbols-outlined">check</span>
            </div>
            <h3 class="display-xl contact-success-title">¡Solicitud recibida!</h3>
            <p class="body-lg text-muted contact-success-lead">
              Gracias por confiar en nosotros. Un asesor experto se pondrá en contacto contigo en las próximas horas.
            </p>

            <div class="contact-success-card">
              <h4 class="headline-lg contact-success-card-title">¿Qué pasa ahora?</h4>
              <ol class="contact-success-steps">
                <li class="contact-success-step">
                  <span class="contact-success-step-num">1</span>
                  <div>
                    <p class="label-s contact-success-step-title">Revisamos tu perfil</p>
                    <p class="body-md text-muted">Analizamos tu situación para encontrar las mejores opciones del mercado para ti.</p>
                  </div>
                </li>
                <li class="contact-success-step">
                  <span class="contact-success-step-num">2</span>
                  <div>
                    <p class="label-s contact-success-step-title">Te llamamos</p>
                    <p class="body-md text-muted">Un asesor especializado te contactará para presentarte la mejor opción. Sin presiones ni compromiso.</p>
                  </div>
                </li>
                <li class="contact-success-step">
                  <span class="contact-success-step-num">3</span>
                  <div>
                    <p class="label-s contact-success-step-title">Tú decides</p>
                    <p class="body-md text-muted">Si te convence, nos encargamos de todo el papeleo. Si no, tan amigos.</p>
                  </div>
                </li>
              </ol>
            </div>

            <p class="label-xs text-muted contact-success-trust">
              Más de 50.000 usuarios ya confían en nosotros
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    z-index: 2;
    background: var(--color-bg);
    border-radius: var(--radius-2xl);
    margin-bottom: -5rem;
  }

  .contact-panel {
    position: relative;
    overflow: hidden;
    padding: 2rem;
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: var(--color-navy);
    box-shadow: var(--shadow-lift);
  }

  .contact-glow {
    position: absolute;
    top: -6rem;
    right: -6rem;
    width: 24rem;
    height: 24rem;
    border-radius: var(--radius-full);
    background: rgba(30, 95, 140, 0.4);
    filter: blur(5rem);
    pointer-events: none;
  }

  .contact-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  .contact-title {
    margin-bottom: 1.5rem;
    color: #ffffff;
  }

  .contact-lead {
    margin-bottom: 2rem;
  }

  .contact-perks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .contact-perk {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #ffffff;
  }

  .contact-perk-icon {
    font-family: 'Material Symbols Outlined';
    font-size: var(--size-lg);
    color: var(--color-orange);
  }

  .contact-form-wrap {
    padding: 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    box-shadow: var(--shadow-soft);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .contact-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-fieldset {
    border: none;
    padding: 0;
    margin: 0;
  }

  .contact-checks {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .contact-check {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-navy);
    cursor: pointer;
  }

  .contact-check input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-navy);
  }

  .contact-label {
    color: var(--color-navy);
  }

  .contact-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    color: var(--color-navy);
    transition: border-color 0.2s ease;
  }

  .contact-input:focus {
    outline: none;
    border-color: var(--color-navy);
  }

  .contact-file-wrap {
    position: relative;
  }

  .contact-file-input {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  .contact-file-dropzone {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 4.5rem;
    padding: 0.875rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .contact-file-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-lg);
    background: #ffffff;
    border: 1px solid var(--color-border);
    font-family: 'Material Symbols Outlined';
    font-size: 1.375rem;
    color: var(--color-blue);
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .contact-file-copy {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .contact-file-cta {
    color: var(--color-navy);
  }

  .contact-file-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-file-wrap:hover .contact-file-dropzone,
  .contact-file-wrap.is-dragover .contact-file-dropzone {
    border-color: var(--color-blue);
    background: #ffffff;
  }

  .contact-file-wrap:hover .contact-file-icon,
  .contact-file-wrap.is-dragover .contact-file-icon {
    border-color: rgba(30, 95, 140, 0.35);
    color: var(--color-navy);
  }

  .contact-file-input:focus-visible + .contact-file-dropzone {
    border-color: var(--color-navy);
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 42, 77, 0.12);
  }

  .contact-file-wrap.is-filled .contact-file-dropzone {
    border-style: solid;
    border-color: rgba(30, 95, 140, 0.45);
    background: #ffffff;
  }

  .contact-file-wrap.is-filled .contact-file-icon {
    border-color: rgba(30, 95, 140, 0.35);
    background: rgba(30, 95, 140, 0.08);
    color: var(--color-navy);
  }

  .contact-file-wrap.is-filled .contact-file-name {
    color: var(--color-navy);
  }

  .contact-file-hint {
    margin: 0;
  }

  .contact-submit {
    width: 100%;
    margin-top: 0.5rem;
    padding-block: 1rem;
  }

  .contact-status {
    display: none;
    margin: 0;
    text-align: center;
  }

  .contact-status.is-visible {
    display: block;
  }

  .contact-status.is-success {
    color: #1b7f45;
  }

  .contact-status.is-error {
    color: #b42318;
  }

  .contact-disclaimer {
    text-align: center;
  }

  .contact-disclaimer a {
    color: var(--color-blue);
    text-decoration: underline;
  }

  .contact-disclaimer a:hover {
    color: var(--color-navy);
  }

  .contact-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .contact-success[hidden] {
    display: none;
  }

  .contact-form.is-hidden {
    display: none;
  }

  .contact-success-icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: rgba(30, 95, 140, 0.12);
    color: var(--color-blue);
  }

  .contact-success-icon .material-symbols-outlined {
    font-size: 1.5rem;
    font-variation-settings: 'FILL' 1;
  }

  .contact-success-title {
    font-size: calc(var(--size-xl) * 0.55);
    color: var(--color-navy);
  }

  .contact-success-lead {
    max-width: 28rem;
  }

  .contact-success-card {
    width: 100%;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: var(--color-bg);
    text-align: left;
  }

  .contact-success-card-title {
    margin-bottom: 1.25rem;
    color: var(--color-navy);
    text-align: center;
  }

  .contact-success-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-success-step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-success-step-num {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(30, 95, 140, 0.1);
    color: var(--color-blue);
    font-size: var(--size-s);
    font-weight: 700;
  }

  .contact-success-step-title {
    margin-bottom: 0.25rem;
    color: var(--color-navy);
  }

  .contact-success-trust {
    margin-top: 0.5rem;
  }

  @media (min-width: 48rem) {
    .contact-panel {
      padding: 4rem;
    }

    .contact-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  import {
    buildLeadBody,
    calculatorToLeadFields,
    clearCalculatorData,
    getCalculatorData,
    submitLandingLead,
  } from '../lib/landingLead';

  const form = document.querySelector('[data-contact-form]');

  if (form instanceof HTMLFormElement) {
    const status = form.querySelector('[data-form-status]');
    const success = form.parentElement?.querySelector('[data-contact-success]');
    const submit = form.querySelector('button[type="submit"]');
    const submitLabel = submit instanceof HTMLButtonElement ? submit.textContent : 'Enviar';
    const fileInput = form.querySelector('[data-contact-file]');
    const fileWrap = form.querySelector('[data-file-wrap]');
    const fileName = form.querySelector('[data-file-name]');
    const filePlaceholder = fileName instanceof HTMLElement ? fileName.textContent : 'o arrastra aquí';

    const calcData = getCalculatorData();
    if (calcData) {
      const fields = calculatorToLeadFields(calcData);
      const nameInput = form.querySelector<HTMLInputElement>('[name="name"]');
      const phoneInput = form.querySelector<HTMLInputElement>('[name="phone"]');
      const consumptionInput = form.querySelector<HTMLInputElement>('[name="approximate_consumption"]');
      const luzCheck = form.querySelector<HTMLInputElement>('[name="service_luz"]');
      const gasCheck = form.querySelector<HTMLInputElement>('[name="service_gas"]');

      if (nameInput && fields.fullName && !nameInput.value) nameInput.value = fields.fullName;
      if (phoneInput && fields.phone && !phoneInput.value) phoneInput.value = fields.phone;
      if (consumptionInput && fields.approximateConsumption && !consumptionInput.value) {
        consumptionInput.value = fields.approximateConsumption;
      }
      if (luzCheck && fields.serviceLuz) luzCheck.checked = true;
      if (gasCheck && fields.serviceGas) gasCheck.checked = true;
    }

    const showSuccess = () => {
      form.classList.add('is-hidden');
      if (success instanceof HTMLElement) success.hidden = false;
      form.parentElement?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };

    const syncFileField = () => {
      if (!(fileInput instanceof HTMLInputElement) || !(fileWrap instanceof HTMLElement)) return;

      const file = fileInput.files?.[0];
      fileWrap.classList.toggle('is-filled', Boolean(file));

      if (fileName instanceof HTMLElement) {
        fileName.textContent = file ? file.name : filePlaceholder;
      }
    };

    if (fileInput instanceof HTMLInputElement && fileWrap instanceof HTMLElement) {
      fileInput.addEventListener('change', syncFileField);

      ['dragenter', 'dragover'].forEach((eventName) => {
        fileWrap.addEventListener(eventName, (event) => {
          event.preventDefault();
          fileWrap.classList.add('is-dragover');
        });
      });

      ['dragleave', 'drop'].forEach((eventName) => {
        fileWrap.addEventListener(eventName, () => {
          fileWrap.classList.remove('is-dragover');
        });
      });

      fileWrap.addEventListener('drop', (event) => {
        event.preventDefault();
        const file = event.dataTransfer?.files?.[0];
        if (!file) return;

        const transfer = new DataTransfer();
        transfer.items.add(file);
        fileInput.files = transfer.files;
        syncFileField();
      });

      form.addEventListener('reset', () => {
        window.requestAnimationFrame(syncFileField);
      });
    }

    const setStatus = (message, type) => {
      if (!(status instanceof HTMLElement)) return;
      status.textContent = message;
      status.className = `label-s contact-status is-visible is-${type}`;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const endpoint = form.dataset.endpoint;
      const apiKey = form.dataset.apiKey;
      const source = form.dataset.source || 'novalux';

      if (!endpoint || !apiKey) {
        setStatus('El formulario no está configurado. Inténtalo más tarde.', 'error');
        return;
      }

      const data = new FormData(form);
      const calculatorData = getCalculatorData();
      const calcFields = calculatorData ? calculatorToLeadFields(calculatorData) : null;
      const consumption = String(data.get('approximate_consumption') ?? '').trim();

      const body = buildLeadBody({
        source,
        leadOrigin: calculatorData ? 'both' : 'contact',
        fullName: String(data.get('name') ?? '').trim(),
        phone: String(data.get('phone') ?? '').trim(),
        email: String(data.get('email') ?? '').trim(),
        clientType: String(data.get('client_type') ?? '').trim(),
        approximateConsumption: consumption || calcFields?.approximateConsumption,
        serviceLuz: Boolean(data.get('service_luz')) || Boolean(calcFields?.serviceLuz),
        serviceGas: Boolean(data.get('service_gas')) || Boolean(calcFields?.serviceGas),
        postalCode: calcFields?.postalCode,
        monthlyBill: calcFields?.monthlyBill,
        savingsPercent: calcFields?.savingsPercent,
        monthlySaving: calcFields?.monthlySaving,
        calculatorData,
        invoice: data.get('invoice') instanceof File && (data.get('invoice') as File).size > 0
          ? (data.get('invoice') as File)
          : undefined,
      });

      if (submit instanceof HTMLButtonElement) {
        submit.disabled = true;
        submit.textContent = 'Enviando...';
      }

      try {
        await submitLandingLead(endpoint, apiKey, body);

        form.reset();
        syncFileField();
        clearCalculatorData();
        showSuccess();
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'No se pudo enviar el formulario', 'error');
      } finally {
        if (submit instanceof HTMLButtonElement) {
          submit.disabled = false;
          submit.textContent = submitLabel ?? 'Solicitar información';
        }
      }
    });
  }
</script>
