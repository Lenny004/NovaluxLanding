---
const perks = [
  'Sin cuotas de entrada',
  'Formación continua gratuita',
  'Soporte dedicado',
];

const clientTypes = [
  { label: 'Autónomo', value: 'autonomo' },
  { label: 'Empresa', value: 'empresa' },
  { label: 'Particular', value: 'particular' },
];

const crmEndpoint = import.meta.env.PUBLIC_CRM_LANDING_LEADS_ENDPOINT ?? 'https://TU_DOMINIO_CRM/PTR-Sales/api/public/api_landing_leads.php?action=create';
const crmApiKey = import.meta.env.PUBLIC_NOVALUX_LANDING_API_KEY ?? '';
---

<section class="contact section" id="contacto">
  <div class="container">
    <div class="contact__panel" data-reveal>
      <div class="contact__glow" aria-hidden="true"></div>

      <div class="contact__grid">
        <div class="contact__intro">
          <h2 class="display-xl contact__title">Únete a la red líder hoy</h2>
          <p class="body-lg text-inverse contact__lead">
            Déjanos tus datos y un asesor se pondrá en contacto contigo para explicarte el programa de colaboración y darte de alta.
          </p>

          <ul class="contact__perks">
            {perks.map((perk) => (
              <li class="contact__perk">
                <span class="material-symbols-outlined contact__perk-icon" aria-hidden="true">check_circle</span>
                <span class="body-md">{perk}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="contact__form-wrap">
          <form
            class="contact__form"
            method="post"
            enctype="multipart/form-data"
            data-contact-form
            data-endpoint={crmEndpoint}
            data-api-key={crmApiKey}
            data-source="novalux"
          >
            <div class="contact__field">
              <label class="label-s contact__label" for="contact-name">Nombre completo</label>
              <input
                class="contact__input"
                id="contact-name"
                name="name"
                type="text"
                placeholder="Ej. Juan Pérez"
                required
              />
            </div>

            <div class="contact__row">
              <div class="contact__field">
                <label class="label-s contact__label" for="contact-phone">Teléfono</label>
                <input
                  class="contact__input"
                  id="contact-phone"
                  name="phone"
                  type="tel"
                  placeholder="+34 600 000 000"
                  required
                />
              </div>
              <div class="contact__field">
                <label class="label-s contact__label" for="contact-email">Email</label>
                <input
                  class="contact__input"
                  id="contact-email"
                  name="email"
                  type="email"
                  placeholder="juan@email.com"
                  required
                />
              </div>
            </div>

            <div class="contact__field">
              <label class="label-s contact__label" for="contact-client-type">Tipo de cliente</label>
              <select class="contact__input" id="contact-client-type" name="client_type" required>
                <option value="" disabled selected>Selecciona una opción</option>
                {clientTypes.map((type) => (
                  <option value={type.value}>{type.label}</option>
                ))}
              </select>
            </div>

            <div class="contact__field">
              <label class="label-s contact__label" for="contact-consumption">Consumo aproximado</label>
              <input
                class="contact__input"
                id="contact-consumption"
                name="approximate_consumption"
                type="text"
                placeholder="Ej. 150€/mes o 3.500 kWh/año"
              />
            </div>

            <fieldset class="contact__field contact__fieldset">
              <legend class="label-s contact__label">Servicios de interés</legend>
              <div class="contact__checks">
                <label class="contact__check">
                  <input type="checkbox" name="service_luz" value="1" />
                  <span>Luz</span>
                </label>
                <label class="contact__check">
                  <input type="checkbox" name="service_gas" value="1" />
                  <span>Gas</span>
                </label>
              </div>
            </fieldset>

            <div class="contact__field">
              <span class="label-s contact__label" id="contact-invoice-label">Subir factura</span>
              <div class="contact__file-wrap" data-file-wrap>
                <input
                  class="contact__file-input"
                  id="contact-invoice"
                  name="invoice"
                  type="file"
                  accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/jpeg,image/png"
                  aria-labelledby="contact-invoice-label contact-invoice-name"
                  data-contact-file
                />
                <label class="contact__file-dropzone" for="contact-invoice" data-file-dropzone>
                  <span class="material-symbols-outlined contact__file-icon" aria-hidden="true">upload_file</span>
                  <span class="contact__file-copy">
                    <span class="label-s contact__file-cta">Seleccionar archivo</span>
                    <span class="label-xs text-muted contact__file-name" id="contact-invoice-name" data-file-name>
                      o arrastra aquí
                    </span>
                  </span>
                </label>
              </div>
              <p class="label-xs text-muted contact__file-hint">PDF, JPG o PNG. Máximo 10 MB.</p>
            </div>

            <button class="btn-primary contact__submit" type="submit">
              Solicitar información
            </button>

            <p class="label-s contact__status" data-form-status aria-live="polite"></p>

            <p class="label-xs text-muted contact__disclaimer">
              Al enviar aceptas nuestra <a class="label-xs" href="/privacidad">política de privacidad</a> y consientes que tus datos se registren en el CRM de gestión comercial para que NOVALUX Energy Partners y empresas colaboradoras te contacten con ofertas personalizadas.
            </p>
          </form>

          <div class="contact__success" data-contact-success hidden>
            <div class="contact__success-icon" aria-hidden="true">
              <span class="material-symbols-outlined">check</span>
            </div>
            <h3 class="display-xl contact__success-title">¡Solicitud recibida!</h3>
            <p class="body-lg text-muted contact__success-lead">
              Gracias por confiar en nosotros. Un asesor experto se pondrá en contacto contigo en las próximas horas.
            </p>

            <div class="contact__success-card">
              <h4 class="headline-lg contact__success-card-title">¿Qué pasa ahora?</h4>
              <ol class="contact__success-steps">
                <li class="contact__success-step">
                  <span class="contact__success-step-num">1</span>
                  <div>
                    <p class="label-s contact__success-step-title">Revisamos tu perfil</p>
                    <p class="body-md text-muted">Analizamos tu situación para encontrar las mejores opciones del mercado para ti.</p>
                  </div>
                </li>
                <li class="contact__success-step">
                  <span class="contact__success-step-num">2</span>
                  <div>
                    <p class="label-s contact__success-step-title">Te llamamos</p>
                    <p class="body-md text-muted">Un asesor especializado te contactará para presentarte la mejor opción. Sin presiones ni compromiso.</p>
                  </div>
                </li>
                <li class="contact__success-step">
                  <span class="contact__success-step-num">3</span>
                  <div>
                    <p class="label-s contact__success-step-title">Tú decides</p>
                    <p class="body-md text-muted">Si te convence, nos encargamos de todo el papeleo. Si no, tan amigos.</p>
                  </div>
                </li>
              </ol>
            </div>

            <p class="label-xs text-muted contact__success-trust">
              Más de 50.000 usuarios ya confían en nosotros
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    z-index: 2;
    background: var(--color-bg);
    border-radius: var(--radius-2xl);
    margin-bottom: -5rem;
  }

  .contact__panel {
    position: relative;
    overflow: hidden;
    padding: 2rem;
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: var(--color-navy);
    box-shadow: var(--shadow-lift);
  }

  .contact__glow {
    position: absolute;
    top: -6rem;
    right: -6rem;
    width: 24rem;
    height: 24rem;
    border-radius: var(--radius-full);
    background: rgba(30, 95, 140, 0.4);
    filter: blur(5rem);
    pointer-events: none;
  }

  .contact__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  .contact__title {
    margin-bottom: 1.5rem;
    color: #ffffff;
  }

  .contact__lead {
    margin-bottom: 2rem;
  }

  .contact__perks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .contact__perk {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #ffffff;
  }

  .contact__perk-icon {
    font-family: 'Material Symbols Outlined';
    font-size: var(--size-lg);
    color: var(--color-orange);
  }

  .contact__form-wrap {
    padding: 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    box-shadow: var(--shadow-soft);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact__fieldset {
    border: none;
    padding: 0;
    margin: 0;
  }

  .contact__checks {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .contact__check {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-navy);
    cursor: pointer;
  }

  .contact__check input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-navy);
  }

  .contact__label {
    color: var(--color-navy);
  }

  .contact__input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    color: var(--color-navy);
    transition: border-color 0.2s ease;
  }

  .contact__input:focus {
    outline: none;
    border-color: var(--color-navy);
  }

  .contact__file-wrap {
    position: relative;
  }

  .contact__file-input {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  .contact__file-dropzone {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 4.5rem;
    padding: 0.875rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .contact__file-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-lg);
    background: #ffffff;
    border: 1px solid var(--color-border);
    font-family: 'Material Symbols Outlined';
    font-size: 1.375rem;
    color: var(--color-blue);
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .contact__file-copy {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .contact__file-cta {
    color: var(--color-navy);
  }

  .contact__file-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact__file-wrap:hover .contact__file-dropzone,
  .contact__file-wrap--dragover .contact__file-dropzone {
    border-color: var(--color-blue);
    background: #ffffff;
  }

  .contact__file-wrap:hover .contact__file-icon,
  .contact__file-wrap--dragover .contact__file-icon {
    border-color: rgba(30, 95, 140, 0.35);
    color: var(--color-navy);
  }

  .contact__file-input:focus-visible + .contact__file-dropzone {
    border-color: var(--color-navy);
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(14, 42, 77, 0.12);
  }

  .contact__file-wrap--filled .contact__file-dropzone {
    border-style: solid;
    border-color: rgba(30, 95, 140, 0.45);
    background: #ffffff;
  }

  .contact__file-wrap--filled .contact__file-icon {
    border-color: rgba(30, 95, 140, 0.35);
    background: rgba(30, 95, 140, 0.08);
    color: var(--color-navy);
  }

  .contact__file-wrap--filled .contact__file-name {
    color: var(--color-navy);
  }

  .contact__file-hint {
    margin: 0;
  }

  .contact__submit {
    width: 100%;
    margin-top: 0.5rem;
    padding-block: 1rem;
  }

  .contact__status {
    display: none;
    margin: 0;
    text-align: center;
  }

  .contact__status--visible {
    display: block;
  }

  .contact__status--success {
    color: #1b7f45;
  }

  .contact__status--error {
    color: #b42318;
  }

  .contact__disclaimer {
    text-align: center;
  }

  .contact__disclaimer a {
    color: var(--color-blue);
    text-decoration: underline;
  }

  .contact__disclaimer a:hover {
    color: var(--color-navy);
  }

  .contact__success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .contact__success[hidden] {
    display: none;
  }

  .contact__form--hidden {
    display: none;
  }

  .contact__success-icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: rgba(30, 95, 140, 0.12);
    color: var(--color-blue);
  }

  .contact__success-icon .material-symbols-outlined {
    font-size: 1.5rem;
    font-variation-settings: 'FILL' 1;
  }

  .contact__success-title {
    font-size: calc(var(--size-xl) * 0.55);
    color: var(--color-navy);
  }

  .contact__success-lead {
    max-width: 28rem;
  }

  .contact__success-card {
    width: 100%;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: var(--color-bg);
    text-align: left;
  }

  .contact__success-card-title {
    margin-bottom: 1.25rem;
    color: var(--color-navy);
    text-align: center;
  }

  .contact__success-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__success-step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact__success-step-num {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(30, 95, 140, 0.1);
    color: var(--color-blue);
    font-size: var(--size-s);
    font-weight: 700;
  }

  .contact__success-step-title {
    margin-bottom: 0.25rem;
    color: var(--color-navy);
  }

  .contact__success-trust {
    margin-top: 0.5rem;
  }

  @media (min-width: 48rem) {
    .contact__panel {
      padding: 4rem;
    }

    .contact__row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  import { initContactForm } from '../scripts/contact-form';

  initContactForm();
</script>
